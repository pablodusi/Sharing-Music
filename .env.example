# API
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Database
DATABASE_URL=postgresql://sharing_music:sharing_music@localhost:5432/sharing_music?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.sharing-music.local
AUTH0_ISSUER_URL=https://your-tenant.auth0.com/

# Voice uploads (local MVP disk path relative to apps/api cwd)
VOICE_UPLOAD_DIR=uploads/voice

# Web — put in apps/web/.env.local
# YOUTUBE_API_KEY=
# NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
